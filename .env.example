# OPC Marketplace - 环境配置示例

# 项目基本信息
PROJECT_NAME=OPC Marketplace
API_V1_STR=/api/v1

# 环境配置
ENVIRONMENT=development
DEBUG=true

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./opc_marketplace.db
# 生产环境使用PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/opc_marketplace

# JWT配置
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7天
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS配置
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:8080", "https://mokangmedical.github.io"]

# 受信任主机
ALLOWED_HOSTS=["localhost", "127.0.0.1", "*"]

# 密码配置
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=100

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=[".jpg", ".jpeg", ".png", ".gif", ".pdf", ".doc", ".docx"]

# 邮件配置（可选）
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@opc-marketplace.com
EMAILS_FROM_NAME=OPC Marketplace

# Redis配置（可选）
REDIS_URL=redis://localhost:6379

# 匹配算法权重
MATCH_SCORE_WEIGHTS={"skill_match": 0.35, "experience_match": 0.25, "budget_match": 0.20, "location_match": 0.10, "availability_match": 0.10}

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 缓存配置
CACHE_EXPIRE_MINUTES=30